# ── AI Model (DistilBERT via AIService) ─────────────────────────────────────
# HuggingFace model ID or path to a local fine-tuned model directory.
# Default works out of the box — swap for your fine-tuned model once ready.
MODEL_NAME=distilbert-base-uncased

# ── Blockchain (get from Person 1 after contract deployment) ────────────────
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS
CONTRACT_ABI=[]

# ── Polygon Amoy RPC ────────────────────────────────────────────────────────
ALCHEMY_AMOY_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Backend Wallet ──────────────────────────────────────────────────────────
# ⚠️  NEVER commit this to Git. Add .env to .gitignore immediately.
BACKEND_PRIVATE_KEY=0xYOUR_FUNDED_WALLET_PRIVATE_KEY
